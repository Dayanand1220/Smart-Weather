{
  "name": "smart-weather-app",
  "version": "1.0.0",
  "description": "Smart Weather Forecasting Web Application",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
    "client": "cd frontend && npm start",
    "client:build": "cd frontend && npm run build",
    "dev:all": "concurrently \"npm run dev\" \"npm run client\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:frontend": "node tests/frontend/run-tests.js",
    "test:selenium": "jest --testMatch=**/tests/frontend/**/*.test.js",
    "test:e2e": "node run-complete-tests.js",
    "test:complete": "node run-complete-tests.js"
  },
  "keywords": [
    "weather",
    "forecast",
    "openweathermap"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "node-cache": "^5.1.2",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "selenium-webdriver": "^4.15.0"
  }
}
